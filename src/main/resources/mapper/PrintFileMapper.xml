<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.farm.mapper.PrintFileMapper">

    <!-- 统计指定文件的打印任务数量 -->
    <select id="countPrintJobsByFileId" resultType="java.lang.Integer">
        SELECT COUNT(*)
        FROM farm_print_job
        WHERE file_id = #{fileId}
          AND user_id = #{userId}
        <if test="status != null">
            AND status = #{status}
        </if>
    </select>

</mapper>
